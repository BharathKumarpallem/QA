# Environment Configuration for AI Document Q&A Service
ENVIRONMENT=development
APP_NAME="AI Document Q&A Service"
APP_VERSION="1.0.0"

# LLM & Embedding configuration
# Replace with your actual OpenAI API Key
OPENAI_API_KEY=your-openai-api-key-here

# Vector Database path
# ChromaDB persistence directory
CHROMA_DB_PATH=./chroma_db

# Document Ingestion parameters
# Maximum PDF upload size in megabytes
MAX_UPLOAD_SIZE_MB=10

# Text chunking configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Semantic similarity threshold
# Chunks below this similarity score will be ignored to prevent hallucinations
SIMILARITY_THRESHOLD=0.55
